<Window x:Class="double_pendulum.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:double_pendulum.Presentation"
        xmlns:controls="clr-namespace:double_pendulum.Presentation.Views.Controls"
        xmlns:vm="clr-namespace:double_pendulum.Presentation.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/Icons/dp-icon.ico"
        Title="Double Pendulum" Height="650" Width="1000" MinWidth="600" MinHeight="400"
        Focusable="True" PreviewMouseDown="Window_PreviewMouseDown">
    
    <Window.Resources>
        <!-- Style for the Buttons -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="MaxWidth" Value="250"/>
            <Setter Property="MaxHeight" Value="65"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for the Checkbox -->
        <Style TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="checkBorder" Width="22" Height="22" Background="Transparent"
                                BorderThickness="2" BorderBrush="White" CornerRadius="6">
                            <TextBlock x:Name="checkMark" Text="✔" FontSize="14" FontWeight="Bold" Foreground="White"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Margin="0,0,0,3" Visibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="checkBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- 2 Row setup -->
    <Grid Background="#FF1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="90*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <!-- 3 Column setup -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <!-- Sliders for Lenghts & Masses 1 & 2 -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <controls:QuantitySlider Grid.Row="0" Margin="10,0,0,0" SliderColor="#2ba637" Quantity="L₁"
                                         MinSliderValue="0.5" MaxSliderValue="4" QuantityValue="{Binding Length1}"
                                         QuantityUnit="m" TickFrequency="0.5" ValueStringFormat="F1"/>
                <controls:QuantitySlider Grid.Row="1" Margin="10,0,0,0" SliderColor="#2ba637" Quantity="L₂"
                                         MinSliderValue="0.5" MaxSliderValue="4" QuantityValue="{Binding Length2}"
                                         QuantityUnit="m" TickFrequency="0.5" ValueStringFormat="F1"/>
                <controls:QuantitySlider Grid.Row="2" Margin="10,0,0,0" SliderColor="#2e60ab" Quantity="M₁"
                                         MinSliderValue="1" MaxSliderValue="250" QuantityValue="{Binding Mass1}"
                                         QuantityUnit="kg" TickFrequency="1"/>
                <controls:QuantitySlider Grid.Row="3" Margin="10,0,0,0" SliderColor="#2e60ab" Quantity="M₂"
                                         MinSliderValue="1" MaxSliderValue="250" QuantityValue="{Binding Mass2}"
                                         QuantityUnit="kg" TickFrequency="1"/>

                <Button Grid.Row="5" Margin="30,10,30,10" Content="Reset Speed" Command="{Binding SpeedResetCommand}"
                        Background="#FF2f2f2f" FontSize="18" BorderBrush="Gray"/>
            </Grid>

            <!-- Reset and Start Buttons -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="80*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Margin="30,20,15,20" Content="Reset" Background="Red"
                            IsEnabled="{Binding IsRunning}" Command="{Binding ResetCommand}"/>
                    <Button Grid.Column="1" Margin="15,20,30,20" Content="Start" Background="Green"
                            IsEnabled="{Binding IsNotRunning}" Command="{Binding StartCommand}"/>
                </Grid>
                <Grid Grid.Row="1">
                    <Canvas x:Name="PendulumCanvas" Background="Transparent"
                            Loaded="PendulumCanvas_Loaded" SizeChanged="PendulumCanvas_SizeChanged"/>
                </Grid>
            </Grid>

            <!-- Sliders for Damping and inital angles -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="60*"/>
                    <RowDefinition Height="10*"/>
                </Grid.RowDefinitions>
                <controls:QuantitySlider Grid.Row="0" Margin="0,0,10,0" SliderColor="#d62f4b" Quantity="D"
                                         MinSliderValue="0" MaxSliderValue="100" QuantityValue="{Binding Damp}"
                                         QuantityUnit="" TickFrequency="1"/>
                <controls:QuantitySlider Grid.Row="1" Margin="0,0,10,0" SliderColor="#e6de87" Quantity="θ₁"
                                         MinSliderValue="-180" MaxSliderValue="180" QuantityValue="{Binding Angle1}"
                                         QuantityUnit="°" TickFrequency="1"/>
                <controls:QuantitySlider Grid.Row="2" Margin="0,0,10,0" SliderColor="#e6de87" Quantity="θ₂"
                                         MinSliderValue="-180" MaxSliderValue="180" QuantityValue="{Binding Angle2}"
                                         QuantityUnit="°" TickFrequency="1"/>

                <!-- CheckBox to enable/disable colorization -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding ShowColors}"/>
                    <TextBlock VerticalAlignment="Center" Text="Show Colors" Foreground="White"
                               FontSize="20" FontWeight="Bold" Margin="8,0,0,1"/>
                </StackPanel>
             </Grid>
        </Grid>

        <!-- Bottom Row for Simulation Speed & Trail Length -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="54*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="44*"/>
            </Grid.ColumnDefinitions>

            <controls:QuantitySlider Grid.Column="0" x:Name="SpeedSlider" Margin="10,0,0,0" SliderColor="White"
                                     Quantity="Simulation Speed" MinSliderValue="0.1" MaxSliderValue="10"
                                     QuantityValue="{Binding SimSpeed}" TickFrequency="0.1" ValueStringFormat="F1"/>
            <controls:QuantitySlider Grid.Column="2" x:Name="TrailLength" SliderColor="Purple"
                                     Quantity="Trail Length" MinSliderValue="0" MaxSliderValue="15"
                                     QuantityValue="{Binding TrailLength}" QuantityUnit="" TickFrequency="0.5" ValueStringFormat="F1"/>
        </Grid>
        
    </Grid>
</Window>
