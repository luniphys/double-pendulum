<Window x:Class="double_pendulum.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:double_pendulum"
        xmlns:controls="clr-namespace:double_pendulum.Views.Controls"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Double Pendulum" Height="450" Width="800" MinWidth="600" MinHeight="400"
        Focusable="True" PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderBrush" Value="WhiteSmoke"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="MinWidth" Value="75"/>
            <Setter Property="MaxWidth" Value="250"/>
            <Setter Property="MaxHeight" Value="65"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#FF1e1e1e">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="60*"/>
            </Grid.RowDefinitions>
            <controls:QuantitySlider Grid.Row="0" x:Name="SliderL1" Margin="10,0,0,0" SliderColor="#2ba637" Quantity="L₁" MinSliderValue="1" MaxSliderValue="5" QuantityValue="1" TickFrequency="0.5"/>
            <controls:QuantitySlider Grid.Row="1" x:Name="SliderL2" Margin="10,0,0,0" SliderColor="#2ba637" Quantity="L₂" MinSliderValue="1" MaxSliderValue="5" QuantityValue="1" TickFrequency="0.5"/>
            <controls:QuantitySlider Grid.Row="2" x:Name="SliderM1" Margin="10,0,0,0" SliderColor="#2e60ab" Quantity="M₁" MinSliderValue="1" MaxSliderValue="50" QuantityValue="10" TickFrequency="1"/>
            <controls:QuantitySlider Grid.Row="3" x:Name="SliderM2" Margin="10,0,0,0" SliderColor="#2e60ab" Quantity="M₂" MinSliderValue="1" MaxSliderValue="50" QuantityValue="10" TickFrequency="1"/>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="80*"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Margin="30,20,15,20" Background="Red" Content="Reset" Click="ResetButton_Click"/>
                <Button Grid.Column="1" Margin="15,20,30,20" Background="Green" Content="Start" Click="StartButton_Click"/>
            </Grid>
            <Grid Grid.Row="1">
                <Canvas x:Name="PendulumCanvas" Background="Transparent"/>
            </Grid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="60*"/>
            </Grid.RowDefinitions>
            <controls:QuantitySlider Grid.Row="0" x:Name="SliderD" Margin="0,0,10,0" SliderColor="#d62f4b" Quantity="D" MinSliderValue="0" MaxSliderValue="20" QuantityValue="1" TickFrequency="1"/>
            <controls:QuantitySlider Grid.Row="1" x:Name="SliderA1" Margin="0,0,10,0" SliderColor="#e6de87" Quantity="θ₁" MinSliderValue="-180" MaxSliderValue="180" QuantityValue="70" TickFrequency="5"/>
            <controls:QuantitySlider Grid.Row="2" x:Name="SliderA2" Margin="0,0,10,0" SliderColor="#e6de87" Quantity="θ₂" MinSliderValue="-180" MaxSliderValue="180" QuantityValue="130" TickFrequency="5"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,5">
                <CheckBox VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" Text="Show Trail" Foreground="White" FontSize="20" FontWeight="Bold" Margin="8,0,0,1"/>
            </StackPanel>

        </Grid>

    </Grid>
</Window>
