<UserControl x:Class="double_pendulum.Views.Controls.QuantitySlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:double_pendulum.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="QuantitySliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track (Rail). Consisting of 3 parts: [=======DecreaseRepeatButton=======][Thumb][==IncreaseRepeatButton==] -->
                            <Border Height="4" Background="#555555" CornerRadius="2"
                                    VerticalAlignment="Center" Margin="5,0"/>
                            <Track x:Name="PART_Track">
                                <!-- Filled portion of the track -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Style="{x:Null}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{Binding SliderColor, RelativeSource={RelativeSource AncestorType=UserControl}}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <!-- Empty portion of the track -->
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Style="{x:Null}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <!-- Pointer (Thumb) -->
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="White"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                   Background="Transparent" Foreground="White"
                   FontSize="20" FontWeight="Bold" Text="{Binding Quantity, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   d:Text="Q₁"/>
        <Slider Grid.Column="1" Name="Sliding" VerticalAlignment="Center" Margin="10,0,5,0"
                Style="{StaticResource QuantitySliderStyle}" Value="{Binding QuantityValue, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Minimum="{Binding MinSliderValue, RelativeSource={RelativeSource AncestorType=UserControl}}" Maximum="{Binding MaxSliderValue, RelativeSource={RelativeSource AncestorType=UserControl}}"
                IsSnapToTickEnabled="True" TickFrequency="{Binding TickFrequency, RelativeSource={RelativeSource AncestorType=UserControl}}"
                d:Minimum="1" d:Maximum="50" d:Value="10"/>
        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" Width="65">
            <TextBox HorizontalAlignment="Right" VerticalAlignment="Center"
                     Background="Transparent" Foreground="White" TextAlignment="Right" CaretBrush="White" BorderThickness="0"
                     FontSize="20" FontWeight="Bold" Text="{Binding QuantityValue, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat=F0}"
                     KeyDown="TextBox_KeyDown"
                     d:Text="145"/>
            <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                     Background="Transparent" Foreground="White" TextAlignment="Left"
                     FontSize="20" FontWeight="Bold" Text="{Binding QuantityUnit, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     d:Text="°"/>
        </StackPanel>
    </Grid>
</UserControl>
